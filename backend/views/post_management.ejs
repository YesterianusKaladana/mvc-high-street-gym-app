<!DOCTYPE html>
<html>
<head>
  <%- include("partials/head.ejs") %>
  <title>HSG - Post Management</title>
</head>

<body class="bg-gray-50 text-gray-900">

<main class="max-w-7xl mx-auto p-6">

  <!-- HEADER -->
  <h1 class="text-3xl font-bold mb-2">Post Management</h1>
  <p class="text-gray-600 mb-6">Create, edit, and manage posts</p>

  <!-- BACK BUTTON -->
  <a href="/authenticate/dashboard"
     class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition mb-6 font-medium">
    ← Back to Dashboard
  </a>

  <!-- GRID -->
  <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">

    <!-- ================= POST LIST ================= -->
    <div class="bg-white border border-gray-200 shadow-sm rounded-xl p-5 overflow-x-auto">

      <h2 class="text-xl font-bold mb-4">Posts</h2>

      <!-- SEARCH -->
      <form method="GET" action="/post" class="mb-4 flex gap-2">

        <input type="text"
               name="search"
               placeholder="Search post title..."
               value="<%= search || '' %>"
               class="w-full border border-gray-300 p-2.5 rounded-lg bg-white
               focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition">

        <button type="submit"
                class="px-4 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium">
          Search
        </button>

        <a href="/post"
           class="px-4 py-2.5 bg-gray-100 text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-200 transition font-medium">
          Clear
        </a>

      </form>

      <!-- HEADER ROW -->
      <div class="grid grid-cols-[2fr_3fr_1fr_auto] text-sm font-semibold text-gray-500 border-b border-gray-200 pb-2 mb-2">
        <span>Title</span>
        <span>Content</span>
        <span>Date</span>
        <span class="text-right">Action</span>
      </div>

      <!-- LIST -->
      <% if (posts && posts.length) { %>
        <% for (const post of posts) { 
            const safeContent = post.content || "";
            const safeDate = post.date ? new Date(post.date) : null;
        %>

          <div class="grid grid-cols-[2fr_3fr_1fr_auto] py-3 border-b border-gray-200 hover:bg-blue-50 transition">

            <!-- TITLE -->
            <span class="font-medium text-gray-900">
              <%= post.title %>
            </span>

            <!-- CONTENT -->
            <span class="text-gray-600">
              <%= safeContent.substring(0, 40) %>
              <% if (safeContent.length > 40) { %>...<% } %>
            </span>

            <!-- DATE -->
            <span class="text-gray-700">
              <%= safeDate && !isNaN(safeDate)
                ? safeDate.toLocaleDateString("en-AU")
                : "-" %>
            </span>

            <!-- ACTION -->
            <span class="text-right">

              <%
                const isOwner =
                  authenticatedUser &&
                  authenticatedUser.id === post.user_id;

                const isAdmin =
                  authenticatedUser &&
                  authenticatedUser.role === "admin";
              %>

              <% if (isOwner) { %>

                <a href="/post/<%= post.id %>"
                   class="text-blue-600 hover:underline font-medium">
                  Edit
                </a>

              <% } else if (isAdmin) { %>

                <a href="/post/<%= post.id %>"
                   class="text-red-600 hover:underline font-medium">
                  Manage
                </a>

              <% } else { %>

                <span class="text-gray-400">
                  No access
                </span>

              <% } %>

            </span>

          </div>

        <% } %>
      <% } else { %>

        <p class="text-gray-500 mt-4">No posts found.</p>

      <% } %>

    </div>

    <!-- ================= FORM ================= -->
    <div class="bg-white border border-gray-200 shadow-sm rounded-xl p-6">

      <%
        const isEdit = selectedPost && selectedPost.id;
        const canEdit = isEdit && authenticatedUser && selectedPost.user_id === authenticatedUser.id;
      %>

      <h2 class="text-xl font-bold mb-4">
        <%= isEdit ? "Edit Post" : "Create Post" %>
      </h2>

      <form action="/post" method="post" class="space-y-4">

        <input type="hidden" name="id" value="<%= selectedPost?.id || '' %>">

        <!-- DATE -->
        <div>
          <label class="block text-sm font-medium text-gray-700">Date</label>

          <input type="date"
                 name="date"
                 value="<%= selectedPost?.date
                   ? new Date(selectedPost.date).toISOString().split('T')[0]
                   : '' %>"
                 class="w-full mt-1 border border-gray-300 p-2.5 rounded-lg bg-white
                 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"
                 <%= isEdit && !canEdit ? "disabled" : "" %>>
        </div>

        <!-- TITLE -->
        <div>
          <label class="block text-sm font-medium text-gray-700">Title</label>

          <input type="text"
                 name="title"
                 required
                 value="<%= selectedPost?.title || '' %>"
                 class="w-full mt-1 border border-gray-300 p-2.5 rounded-lg bg-white
                 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"
                 <%= isEdit && !canEdit ? "disabled" : "" %>>

                  <% if (error) { %>
                   <p class="text-red-500 text-sm mt-1">
                     <%= error %>
                   </p>
                 <% } %>
        </div>

        <!-- CONTENT -->
        <div>
          <label class="block text-sm font-medium text-gray-700">Content</label>

          <textarea name="content"
                    rows="4"
                    class="w-full mt-1 border border-gray-300 p-2.5 rounded-lg bg-white
                    focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"
                    <%= isEdit && !canEdit ? "disabled" : "" %>><%= selectedPost?.content || '' %></textarea>
        </div>

        <!-- BUTTONS -->
        <div class="flex gap-3 pt-2">

          <button type="reset"
                  class="px-4 py-2.5 bg-gray-100 text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-200 transition font-medium">
            Clear
          </button>

          <!-- CREATE -->
          <% if (!isEdit) { %>

            <button type="submit"
                    name="action"
                    value="create"
                    class="px-4 py-2.5 bg-green-600 text-white rounded-lg hover:bg-green-700 transition font-medium">
              Create
            </button>

          <!-- OWNER EDIT -->
          <% } else if (canEdit) { %>

            <button type="submit"
                    name="action"
                    value="update"
                    class="px-4 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium">
              Update
            </button>

            <button type="submit"
                    name="action"
                    value="delete"
                    class="px-4 py-2.5 bg-red-600 text-white rounded-lg hover:bg-red-700 transition font-medium">
              Delete
            </button>

          <!-- ADMIN -->
          <% } else if (authenticatedUser.role === "admin") { %>

            <span class="text-gray-400 text-sm flex items-center">
              No edit access
            </span>

            <button type="submit"
                    name="action"
                    value="delete"
                    class="px-4 py-2.5 bg-red-600 text-white rounded-lg hover:bg-red-700 transition font-medium">
              Delete
            </button>

          <!-- NO ACCESS -->
          <% } else { %>

            <span class="text-gray-400 text-sm flex items-center">
              You cannot modify this post
            </span>

          <% } %>

        </div>

      </form>

    </div>

  </section>

  <%- include("partials/footer.ejs") %>

</main>

</body>
</html>