<!DOCTYPE html>
<html lang="en">

<head>
  <%- include("./partials/head.ejs") %>
  <title>HSG | Backend</title>
</head>

<body class="bg-gray-50 min-h-screen overflow-x-hidden">

  <%- include("./partials/header.ejs") %>

  <main class="max-w-7xl mx-auto px-4 py-6 sm:px-6">

    <% if (sessionByDay) { %>

      <!-- TIMETABLE SECTION -->
      <section class="mb-12 bg-blue-50 rounded-2xl p-6 md:p-8">

        <h2 class="text-2xl md:text-3xl font-bold mb-6 text-blue-900">
          Weekly Timetable
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 md:gap-6">

          <% Object.keys(sessionByDay).forEach(day => { %>

            <div class="rounded-xl bg-white border border-blue-100 shadow-sm p-5">

              <h3 class="text-xl md:text-2xl font-bold mb-4 text-blue-800">
                <%= day %>
              </h3>

              <% if (!sessionByDay[day] || sessionByDay[day].length === 0) { %>
                <p class="text-gray-500">No sessions available.</p>
              <% } %>

              <% sessionByDay[day].forEach(session => { %>

                <div class="border border-blue-100 rounded-xl p-4 mb-4 shadow-sm bg-white">

                  <!-- SESSION TITLE -->
                  <h4 class="text-lg md:text-xl font-bold text-gray-900 break-words">
                    <%= session.activity_name %>
                  </h4>

                  <!-- DETAILS -->
                  <div class="mt-3 space-y-2 text-sm md:text-base text-gray-700">

                    <p>📍 <%= session.location_name %></p>
                    <p>📅 <%= session.date %></p>
                    <p>🕒 <%= session.start_time %> - <%= session.end_time %></p>
                    <p>🧑 Trainer: <%= session.trainer_name %></p>
                    <p>👥 Capacity: <%= session.capacity %> people</p>

                  </div>

                  <!-- ACTIONS -->
                  <div class="mt-5">

                    <% if (session.isExpired === true) { %>

                      <span class="inline-block px-4 py-3 bg-red-100 text-red-700 rounded-xl text-sm font-semibold w-full text-center">
                        ⛔ Session Expired
                      </span>

                    <% } else if (user && session.isBooked) { %>

                      <span class="inline-block px-4 py-3 bg-green-100 text-green-700 rounded-xl text-sm font-semibold w-full text-center">
                        ✔ Already Booked
                      </span>

                    <% } else if (!user) { %>

                      <a href="/authenticate"
                         class="inline-block w-full text-center bg-blue-500 text-white px-5 py-3 rounded-xl hover:bg-blue-600 transition font-semibold">
                        Login to Book
                      </a>

                    <% } else { %>

                      <form method="POST" action="/session/book/<%= session.session_id %>">
                        <button
                          class="w-full bg-purple-500 text-white px-5 py-3 rounded-xl hover:bg-purple-600 transition font-semibold">
                          Book Session
                        </button>
                      </form>

                    <% } %>

                  </div>

                </div>

              <% }) %>

            </div>

          <% }) %>

        </div>

      </section>

    <% } %>

  </main>

  <%- include("./partials/footer.ejs") %>

</body>
</html>