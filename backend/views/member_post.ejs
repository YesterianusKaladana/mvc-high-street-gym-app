<!DOCTYPE html>
<html>
<head>
  <%- include("partials/head.ejs") %>
  <title>HSG | Member Posts</title>
</head>

<body class="bg-gray-50">

<main class="max-w-5xl mx-auto p-6">

  <!-- BACK BUTTON -->
  <a href="/authenticate/dashboard"
     class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition mb-6 font-medium">
    ← Back to Dashboard
  </a>

  <!-- HEADER -->
  <div class="flex items-center justify-between mb-6">

    <div>
      <h1 class="text-3xl font-bold text-gray-900">Member Feed List</h1>
      <p class="text-gray-600">View all posts in one place</p>
    </div>

   <a href="/post/member/create"
    class="px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700">
    + Create Post
    </a>

  </div>

  <!-- FEED -->
  <% if (posts && posts.length > 0) { %>

    <div class="space-y-4">

      <% posts.forEach(post => { %>

        <article class="bg-gray-100 p-4 rounded-xl border shadow-sm">

          <h2 class="text-xl font-bold text-gray-900">
            <%= post.title %>
          </h2>

          <p class="mt-3 text-gray-700">
            <%= post.content %>
          </p>

          <form action="/post/member/create" method="post">
            <input type="hidden" name="action" value="delete">
            <input type="hidden" name="id" value="<%= post.id %>">

            <button
              type="submit"
              class="mt-4 px-3 py-1.5 bg-red-600 text-white rounded hover:bg-red-700"
            >
              Delete Post
            </button>
          </form>

        </article>

      <% }) %>

    </div>

  <% } else { %>

    <p class="text-gray-500">No posts available.</p>

  <% } %>

</main>

</body>
</html>