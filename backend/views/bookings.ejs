<!DOCTYPE html>
<html lang="en">

<head>
  <%- include("partials/head.ejs") %>
  <title>My Bookings | HSG</title>
</head>

<body class="bg-gray-50 text-gray-900">

<main class="max-w-4xl mx-auto p-6">

  <!-- HEADER -->
  <div class="bg-white border border-gray-200 shadow-sm rounded-xl p-6 mb-6">
    <h1 class="text-2xl font-bold">My Bookings</h1>
    <p class="text-gray-600 mt-1">Your upcoming and past training sessions</p>
  </div>

  <!-- BACK -->
  <a href="/authenticate/dashboard"
     class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 mb-6 transition font-medium">
    ← Back to Dashboard
  </a>

  <!-- CONTENT -->
  <div class="space-y-4">

    <% if (!bookings || bookings.length === 0) { %>

      <div class="bg-white border border-gray-200 rounded-xl p-6 text-center text-gray-500">
        You don’t have any bookings yet.
      </div>

    <% } else { %>

      <% bookings.forEach(function(b) { 
          const s = b.session;
      %>

      <!-- BOOKING CARD -->
      <div class="bg-white border border-gray-200 shadow-sm rounded-xl p-5 hover:shadow-md transition">

        <!-- TOP ROW -->
        <div class="flex justify-between items-start">

          <div>
            <p class="text-sm text-gray-500">
              Booked on <%= b?.created ? new Date(b.created).toLocaleDateString("en-AU") : "-" %>
            </p>

            <h2 class="text-lg font-semibold mt-1">
              <%= s?.activity?.name || "Unknown Activity" %>
            </h2>

            <p class="text-gray-600 mt-1">
              📍 <%= s?.location?.name || "Unknown Location" %>
            </p>

            <p class="text-gray-600">
              🧑‍🏫 Trainer: <%= s?.user?.firstName || "" %> <%= s?.user?.lastName || "" %>
            </p>
          </div>

        </div>

        <!-- BOTTOM ACTION -->
        <div class="mt-4 flex justify-end">

          <form method="POST" action="/booking/member">
            <input type="hidden" name="id" value="<%= b.id %>">
            <input type="hidden" name="action" value="delete">

            <button
              class="text-sm text-red-600 hover:text-red-800 font-medium">
              Cancel booking
            </button>
          </form>

        </div>

      </div>

      <% }) %>

    <% } %>

  </div>

</main>

</body>
</html>