<!DOCTYPE html>
<html lang="en">

<head>
  <%- include("partials/head.ejs") %>
  <title>Member Sessions | HSG</title>
</head>

<body class="bg-gray-100">

<main class="min-h-screen flex flex-col">

  <div class="max-w-7xl mx-auto w-full p-6">

    <div class="mb-6">
      <h1 class="text-2xl font-bold">Available Sessions</h1>
      <p class="text-gray-600">Book your gym sessions below</p>
    </div>

    <a href="/authenticate/dashboard"
       class="mb-6 inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
      ← Back to Dashboard
    </a>

    <% const days = Object.keys(sessionByDay); %>

    <% days.forEach(day => { %>

      <div class="mb-6 bg-white shadow rounded-lg p-5">

        <h2 class="text-lg font-bold mb-3 text-blue-600">
          <%= day %>
        </h2>

        <% if (sessionByDay[day].length === 0) { %>

          <p class="text-gray-500 text-sm">No sessions available</p>

        <% } else { %>

          <div class="grid md:grid-cols-2 gap-4">

            <% sessionByDay[day].forEach(session => { %>

              <div class="border rounded-lg p-4 bg-gray-50">

                <div class="space-y-1">

                  <p class="text-lg font-semibold"><%= session.activity_name %></p>
                  <p class="text-sm text-gray-600">📍 <%= session.location_name %></p>
                  <p class="text-sm text-gray-600">🧑 <%= session.trainer_name %></p>
                  <p class="text-sm text-gray-600">🕒 <%= session.start_time %> - <%= session.end_time %></p>
                  <p class="text-sm text-gray-500">📅 <%= session.date %></p>

                </div>

              <div class="mt-4">

                <%
                  const today = new Date();
                  today.setHours(0,0,0,0);

                  const sessionDate = new Date(session.date);
                  sessionDate.setHours(0,0,0,0);

                  const isPast = sessionDate < today;
                %>

                <!-- BOOKED -->
                <% if (session.isBooked) { %>

                  <div class="flex justify-between items-center">

                    <span class="text-green-600 font-semibold text-sm">
                      ✔ Booked
                    </span>

                    <form method="POST"
                          action="/session/cancel/<%= session.session_id %>">

                      <button
                        class="px-3 py-1 bg-red-500 text-white text-sm rounded hover:bg-red-600">
                        Cancel
                      </button>

                    </form>

                  </div>

                <!-- EXPIRED -->
                <% } else if (isPast) { %>

                  <button
                    disabled
                    class="w-full px-3 py-2 bg-gray-300 text-gray-500 rounded cursor-not-allowed">

                    Expired

                  </button>

                <!-- AVAILABLE -->
                <% } else { %>

                <a href="/booking/member/confirm/<%= session.session_id %>"
                  class="block w-full text-center px-3 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
                  Book Session
                </a>

                <% } %>

              </div>

              </div>

            <% }) %>

          </div>

        <% } %>

      </div>

    <% }) %>

  </div>

</main>

</body>
</html>