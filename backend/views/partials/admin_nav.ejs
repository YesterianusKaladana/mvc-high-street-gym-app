<header class="bg-white shadow sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4">

    <!-- Hidden checkbox -->
    <input type="checkbox" id="menu-toggle" class="peer hidden" />

    <!-- Top bar -->
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/authenticate/dashboard" class="text-lg font-bold text-gray-800">
        HSG Fitness
      </a>

      <!-- Hamburger -->
      <label for="menu-toggle" class="md:hidden p-2 cursor-pointer">
        <svg class="w-8 h-8 text-gray-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </label>

      <!-- Desktop menu -->
      <nav class="hidden md:flex items-center gap-5 text-sm">

       <% if (user && user.role === "admin") { %>
          <a href="/user" class="px-3 py-1.5 bg-blue-600 text-white rounded hover:bg-blue-700">Manage Users</a>
          <a href="/session" class="px-3 py-1.5 bg-blue-600 text-white rounded hover:bg-blue-700">Manage Sessions</a>
          <a href="/activity" class="px-3 py-1.5 bg-blue-600 text-white rounded hover:bg-blue-700">Manage Activities</a>
          <a href="/location" class="px-3 py-1.5 bg-blue-600 text-white rounded hover:bg-blue-700">Manage Locations</a>
          <a href="/post" class="px-3 py-1.5 bg-blue-600 text-white rounded hover:bg-blue-700">Manage Posts</a>
          <a href="/booking" class="px-3 py-1.5 bg-blue-600 text-white rounded hover:bg-blue-700">Manage Bookings</a>
        <% } %>

        <% if (user && user.role === "trainer") { %>
          <a href="/session/trainer/view"
            class="px-3 py-1.5 bg-blue-600 text-white rounded hover:bg-blue-700">
            Manage Sessions
          </a>

          <a href="/post/trainer"
            class="px-3 py-1.5 bg-blue-600 text-white rounded hover:bg-blue-700">
            My Posts
          </a>
        <% } %>

        <% if (user && user.role === "member") { %>
            <a href="/session/member/view"
              class="px-3 py-1.5 bg-blue-600 text-white rounded hover:bg-blue-700">
              Browse Sessions
            </a>

            <a href="/booking/member"
              class="px-3 py-1.5 bg-blue-600 text-white rounded hover:bg-blue-700">
              My Bookings
            </a>

            <a href="/post/member"
              class="px-3 py-1.5 bg-blue-600 text-white rounded hover:bg-blue-700">
              My Posts
            </a>
          <% } %>

        <% if (user && ["admin", "trainer", "member"].includes(user.role)) { %>
          <a href="/authenticate/logout"
             class="px-3 py-1.5 bg-red-600 text-white rounded hover:bg-red-700">
            Logout
          </a>
        <% } %>

      </nav>
    </div>

    <!-- Mobile menu -->
    <nav class="peer-checked:block hidden md:hidden pb-4 space-y-2 text-sm">

      <% if (user && user.role === "admin") { %>
        <a href="/user" class="block px-4 py-3 bg-blue-600 text-white rounded">Users</a>
        <a href="/session" class="block px-4 py-3 bg-blue-600 text-white rounded">Sessions</a>
        <a href="/activity" class="block px-4 py-3 bg-blue-600 text-white rounded">Activities</a>
        <a href="/location" class="block px-4 py-3 bg-blue-600 text-white rounded">Locations</a>
        <a href="/post" class="block px-4 py-3 bg-blue-600 text-white rounded">Posts</a>
        <a href="/booking" class="block px-4 py-3 bg-blue-600 text-white rounded">Bookings</a>
      <% } %>

      <% if (user && user.role === "trainer") { %>
        <a href="/session/trainer/view"
           class="block px-4 py-3 text-gray-700 hover:text-blue-600 hover:bg-gray-100 rounded">
          My Sessions
        </a>

        <a href="/post/trainer"
           class="block px-4 py-3 text-gray-700 hover:text-blue-600 hover:bg-gray-100 rounded">
          My Posts
        </a>
      <% } %>

      <% if (user && user.role === "member") { %>
        <a href="/session/member/view"
           class="block px-4 py-3 text-gray-700 hover:text-blue-600 hover:bg-gray-100 rounded">
          Browse Sessions
        </a>

        <a href="/booking/member"
           class="block px-4 py-3 text-gray-700 hover:text-blue-600 hover:bg-gray-100 rounded">
          My Bookings
        </a>

        <a href="/post/member"
           class="block px-4 py-3 text-gray-700 hover:text-blue-600 hover:bg-gray-100 rounded">
          My Posts
        </a>
      <% } %>

      <% if (user && ["admin", "trainer", "member"].includes(user.role)) { %>
        <a href="/authenticate/logout"
           class="block px-4 py-3 bg-red-600 text-white rounded text-center hover:bg-red-700">
          Logout
        </a>
      <% } %>

    </nav>

  </div>
</header>