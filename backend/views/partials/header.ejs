<header class="bg-gray-400 shadow sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4">
    <!-- Hidden checkbox -->
    <input type="checkbox" id="menu-toggle" class="peer hidden" />

    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="text-base sm:text-lg font-bold text-gray-600">
        HSG Fitness Center
      </a>

      <!-- Hamburger -->
      <label for="menu-toggle" class="cursor-pointer md:hidden">
        <svg
          class="w-8 h-8 text-gray-800"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"
          />
        </svg>
      </label>

      <!-- Desktop menu -->
      <nav class="hidden md:flex items-center gap-4 text-sm">
        <a
          href="/session/view"
          class="px-3 py-2 rounded bg-blue-600 text-white hover:bg-blue-700"
        >
          Timetable
        </a>
        <a
          href="/post/public"
          class="px-3 py-2 rounded bg-blue-600 text-white hover:bg-blue-700"
        >
          Blog
        </a>
        <a
          href="/authenticate"
          class="px-3 py-2 rounded bg-blue-600 text-white hover:bg-blue-700"
        >
          Login
        </a>
        <a
          href="/authenticate/register"
          class="px-3 py-2 rounded bg-blue-600 text-white hover:bg-blue-700"
        >
          Register
        </a>
      </nav>
    </div>

    <!-- Mobile menu -->
    <nav class="hidden peer-checked:block md:hidden pb-4 space-y-3">
      <a
        href="/session/view"
        class="block w-full text-center px-3 py-3 rounded bg-blue-600 text-white hover:bg-blue-700 hover:scale-[1.02] transition"
      >
        Timetable
      </a>

      <a
        href="/post/public"
        class="block w-full text-center px-3 py-3 rounded bg-blue-600 text-white hover:bg-blue-700 hover:scale-[1.02] transition"
      >
        Blog
      </a>

      <a
        href="/authenticate"
        class="block w-full text-center px-3 py-3 rounded bg-blue-600 text-white hover:bg-blue-700 hover:scale-[1.02] transition"
      >
        Login
      </a>

      <a
        href="/authenticate/register"
        class="block w-full text-center px-3 py-3 rounded bg-blue-600 text-white hover:bg-blue-700 hover:scale-[1.02] transition"
      >
        Register
      </a>
    </nav>
  </div>
</header>
