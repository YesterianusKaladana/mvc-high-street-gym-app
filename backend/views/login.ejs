<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head.ejs") %>
  <title>Login | HSG</title>

  <% if (registered === "success") { %>
    <meta http-equiv="refresh" content="2;url=/authenticate" />
  <% } else if (logout === "success") { %>
    <meta http-equiv="refresh" content="2;url=/authenticate" />
  <% } %>
</head>

<body class="bg-gradient-to-br from-gray-900 to-black min-h-screen flex flex-col">

<!-- ================= SUCCESS POPUPS ================= -->
<% if (registered === "success") { %>

  <div class="fixed top-20 inset-x-0 flex justify-center z-[9999]">
    <div class="bg-white border border-green-200 shadow-lg 
                text-green-700 px-6 py-3 rounded-xl flex items-center gap-2">
      ✔ Account created successfully
      <span class="text-gray-500 text-sm">Redirecting...</span>
    </div>
  </div>

<% } else if (logout === "success") { %>

  <div class="fixed top-20 inset-x-0 flex justify-center z-[9999]">
    <div class="bg-white border border-blue-200 shadow-lg 
                text-blue-700 px-6 py-3 rounded-xl flex items-center gap-2">
      👋 You have been logged out successfully
      <span class="text-blue-500 text-sm">Redirecting...</span>
    </div>
  </div>

<% } %>

<!-- ================= HEADER ================= -->
<main class="flex flex-col min-h-screen">
  <%- include("partials/header.ejs") %>

  <!-- ================= LOGIN SECTION ================= -->
  <section class="flex-grow flex items-center justify-center px-4 sm:px-6 lg:px-8 py-12">

    <div class="w-full max-w-md">

      <div class="bg-white rounded-lg shadow-2xl p-8 md:p-10">

        <!-- TITLE -->
        <div class="text-center mb-8">
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">
            Welcome Back
          </h1>
          <p class="text-gray-600">
            Login to your High Street Gym account
          </p>
        </div>

        <!-- FORM -->
        <form action="/authenticate" method="POST" class="space-y-5">

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-2">
              Email Address
            </label>
            <input
              type="email"
              name="email"
              required
              placeholder="your@email.com"
              class="w-full px-4 py-3 border border-gray-300 rounded-xl
                text-gray-900 bg-white
                focus:outline-none focus:ring-2 focus:ring-blue-200
                focus:border-blue-500 transition"
            />
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-2">
              Password
            </label>
            <input
              type="password"
              name="password"
              required
              placeholder="••••••••"
              class="w-full px-4 py-3 border border-gray-300 rounded-xl
            text-gray-900 bg-white
             focus:outline-none focus:ring-2 focus:ring-blue-200
            focus:border-blue-500 transition"
            
            />
          </div>

          <button
            type="submit"
            class="w-full py-3 bg-gradient-to-r from-blue-600 to-blue-700 
                   text-white font-bold rounded-lg hover:from-blue-700 hover:to-blue-800 
                   transition transform hover:scale-105"
          >
            🔓 Log in
          </button>

        </form>

        <!-- DIVIDER -->
        <div class="relative my-8">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-300"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="px-2 bg-white text-gray-500">
              New to HSG?
            </span>
          </div>
        </div>

        <!-- REGISTER -->
        <a
          href="/authenticate/register"
          class="w-full block text-center px-6 py-3 border-2 border-blue-300 
                 text-blue-700 font-bold rounded-lg hover:bg-blue-50 transition"
        >
          Create Account
        </a>

      </div>
    </div>

  </section>

  <%- include("partials/footer.ejs") %>
</main>

</body>
</html>