<!DOCTYPE html>
<html>
<head>
  <%- include("partials/head.ejs") %>
  <title>HSG - Session Management</title>
</head>

<body class="bg-gray-50 text-gray-900">

<main class="max-w-7xl mx-auto p-6">

  <!-- HEADER -->
  <h1 class="text-3xl font-bold mb-2">Session Management</h1>
  <p class="text-gray-600 mb-6">Create, edit, and manage sessions</p>

  <!-- BACK BUTTON -->
  <a href="/authenticate/dashboard"
     class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition mb-6 font-medium">
    ← Back to Dashboard
  </a>

  <!-- GRID -->
  <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">

    <!-- ================= SESSION LIST ================= -->
    <div class="bg-white border border-gray-200 shadow-sm rounded-xl p-5">

      <h2 class="text-xl font-bold mb-4">Sessions</h2>

      <!-- SEARCH -->
      <form method="GET" action="/session" class="mb-4">
        <div class="flex flex-wrap gap-2 items-center">

          <input type="text"
                 name="search"
                 placeholder="Search trainer, location, activity..."
                 value="<%= search || '' %>"
                 class="flex-1 min-w-[220px] border border-gray-300 p-2.5 rounded-lg">

          <input type="date"
                 name="date"
                 value="<%= date || '' %>"
                 class="w-[150px] border border-gray-300 p-2.5 rounded-lg">

          <input type="time"
                 name="start_time"
                 value="<%= start_time || '' %>"
                 class="w-[130px] border border-gray-300 p-2.5 rounded-lg">

          <input type="time"
                 name="end_time"
                 value="<%= end_time || '' %>"
                 class="w-[130px] border border-gray-300 p-2.5 rounded-lg">

          <input type="number"
                 name="capacity"
                 placeholder="Capacity"
                 value="<%= capacity || '' %>"
                 class="w-[100px] border border-gray-300 p-2.5 rounded-lg">

          <button type="submit"
                  class="px-4 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
            Search
          </button>

          <a href="/session"
             class="px-4 py-2.5 bg-gray-100 border border-gray-300 rounded-lg hover:bg-gray-200">
            Clear
          </a>

        </div>
      </form>

      <!-- SESSION LIST -->
      <% if (sessions && sessions.length) { %>
        <div class="space-y-4">

          <% sessions.forEach(s => { %>
            <div class="border border-gray-200 rounded-xl p-4 hover:bg-blue-50 transition">

              <div class="flex justify-between mb-3">
                <div class="font-semibold">
                  <%= s.activity.name %> Session
                </div>

                <a href="/session?edit_id=<%= s.session.id %>"
                   class="text-blue-600 hover:underline">
                  Edit
                </a>
              </div>

              <div class="grid grid-cols-2 gap-3 text-sm">

                <div>
                  <p class="text-gray-500">Trainer</p>
                  <p><%= s.user.firstName %> <%= s.user.lastName %></p>
                </div>

                <div>
                  <p class="text-gray-500">Location</p>
                  <p><%= s.location.name %></p>
                </div>

                <div>
                  <p class="text-gray-500">Date</p>
                  <p><%= s.session.date %></p>
                </div>

                <div>
                  <p class="text-gray-500">Capacity</p>
                  <p><%= s.session.capacity %></p>
                </div>

                <div>
                  <p class="text-gray-500">Start Time</p>
                  <p><%= s.session.start_time %></p>
                </div>

                <div>
                  <p class="text-gray-500">End Time</p>
                  <p><%= s.session.end_time %></p>
                </div>

              </div>

            </div>
          <% }) %>

        </div>
      <% } else { %>
        <p class="text-gray-500 mt-4">No sessions found.</p>
      <% } %>

    </div>

    <!-- ================= FORM ================= -->
    <div class="bg-white border border-gray-200 shadow-sm rounded-xl p-6">

      <% const isEdit = selectedSession?.session?.id; %>

      <h2 class="text-xl font-bold mb-4">
        <%= isEdit ? "Edit Session" : "Create Session" %>
      </h2>

      <form action="<%= isEdit ? '/session/' + selectedSession.session.id : '/session' %>"
            method="post"
            class="space-y-4">

        <input type="hidden"
               name="session_id"
               value="<%= selectedSession?.session?.id || '' %>">

        <!-- TRAINER / LOCATION / ACTIVITY -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

          <div>
            <label class="block text-sm font-medium">Trainer</label>
            <select name="user_id" required class="w-full mt-1 border p-2.5 rounded-lg">
              <option value="">Select Trainer</option>
              <% users.forEach(u => { %>
                <option value="<%= u.id %>"
                  <%= selectedSession?.session?.user_id === u.id ? "selected" : "" %>>
                  <%= u.firstName %> <%= u.lastName %>
                </option>
              <% }) %>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium">Location</label>
            <select name="location_id" required class="w-full mt-1 border p-2.5 rounded-lg">
              <option value="">Select Location</option>
              <% locations.forEach(l => { %>
                <option value="<%= l.id %>"
                  <%= selectedSession?.session?.location_id === l.id ? "selected" : "" %>>
                  <%= l.name %>
                </option>
              <% }) %>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium">Activity</label>
            <select name="activity_id" required class="w-full mt-1 border p-2.5 rounded-lg">
              <option value="">Select Activity</option>
              <% activities.forEach(a => { %>
                <option value="<%= a.id %>"
                  <%= selectedSession?.session?.activity_id === a.id ? "selected" : "" %>>
                  <%= a.name %>
                </option>
              <% }) %>
            </select>
          </div>

        </div>

        <!-- DATE (BLOCK PAST DATE) -->
        <div>
          <label class="block text-sm font-medium">Date</label>
          <input type="date"
                 name="date"
                 required
                 min="<%= new Date().toISOString().split('T')[0] %>"
                 value="<%= selectedSession?.session?.date || '' %>"
                 class="w-full mt-1 border p-2.5 rounded-lg">
        </div>

        <!-- TIME -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

          <div>
            <label class="block text-sm font-medium">Start Time</label>
            <input type="time"
                   name="start_time"
                   required
                   value="<%= selectedSession?.session?.start_time || '' %>"
                   class="w-full mt-1 border p-2.5 rounded-lg">
          </div>

          <div>
            <label class="block text-sm font-medium">End Time</label>
            <input type="time"
                   name="end_time"
                   required
                   value="<%= selectedSession?.session?.end_time || '' %>"
                   class="w-full mt-1 border p-2.5 rounded-lg">
          </div>

        </div>

        <!-- CAPACITY -->
        <div>
          <label class="block text-sm font-medium">Capacity</label>
          <input type="number"
                 name="capacity"
                 min="1"
                 step="1"
                 required
                 value="<%= selectedSession?.session?.capacity || '' %>"
                 class="w-full mt-1 border p-2.5 rounded-lg">
        </div>

        <!-- BUTTONS -->
        <div class="flex gap-3 pt-2">

          <button type="reset"
                  class="px-4 py-2 bg-gray-100 border rounded-lg">
            Clear
          </button>

          <% if (!isEdit) { %>

            <button type="submit" name="action" value="create"
                    class="px-4 py-2 bg-green-600 text-white rounded-lg">
              Create
            </button>

          <% } else { %>

            <button type="submit" name="action" value="update"
                    class="px-4 py-2 bg-blue-600 text-white rounded-lg">
              Update
            </button>

            <button type="submit" name="action" value="delete"
                    class="px-4 py-2 bg-red-600 text-white rounded-lg">
              Delete
            </button>

          <% } %>

        </div>

      </form>

    </div>

  </section>

  <%- include("partials/footer.ejs") %>

</main>

</body>
</html>