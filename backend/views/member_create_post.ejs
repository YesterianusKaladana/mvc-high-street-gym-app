<!DOCTYPE html>
<html>
<head>
  <%- include("partials/head.ejs") %>
  <title>HSG | Member Create Post</title>
</head>

<body class="bg-gray-50">

<main class="max-w-2xl mx-auto p-6">

  <!-- BACK -->
  <a href="/post/member"
     class="inline-block mb-6 text-blue-600 hover:underline">
    ← Back to Feed
  </a>

  <h1 class="text-3xl font-bold mb-6">Create New Post</h1>

  <form
    action="/post/member/create"
    method="post"
    class="space-y-4 bg-white p-6 rounded-xl shadow"
  >

    <input type="hidden" name="action" value="create">

    <!-- TITLE -->
    <div>
      <label for="title" class="block font-medium">
        Title
      </label>

      <input
        id="title"
        type="text"
        name="title"
        required
        class="w-full border p-2 rounded mt-1"
      >
    </div>

    <!-- CONTENT -->
    <div>
      <label for="content" class="block font-medium">
        Content
      </label>

      <textarea
        id="content"
        name="content"
        rows="6"
        required
        class="w-full border p-2 rounded mt-1"
      ></textarea>
    </div>

    <!-- ERROR MESSAGE -->
    <% if (error) { %>
      <div class="bg-red-100 border border-red-300 text-red-700 px-4 py-3 rounded">
        <%= error %>
      </div>
    <% } %>

    <!-- BUTTONS -->
    <div class="flex gap-3 pt-2">

      <button
        type="submit"
        class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700"
      >
        Publish Post
      </button>

      <a
        href="/post/member"
        class="bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600"
      >
        Cancel
      </a>

    </div>

  </form>

</main>

</body>
</html>