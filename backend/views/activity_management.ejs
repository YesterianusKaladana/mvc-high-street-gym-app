<!DOCTYPE html>
<html>
<head>
  <%- include("partials/head.ejs") %>
  <title>HSG - Activity Management</title>
</head>

<body class="bg-gray-50 text-gray-900">

<main class="max-w-7xl mx-auto p-6">

  <!-- HEADER -->
  <h1 class="text-3xl font-bold mb-2">Activity Management</h1>
  <p class="text-gray-600 mb-6">
    Create, edit, and manage activities
  </p>

  <!-- BACK BUTTON -->
  <a href="/authenticate/dashboard"
     class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition mb-6 font-medium">
    ← Back to Dashboard
  </a>

  <!-- GRID -->
  <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">

    <!-- ================= ACTIVITY LIST ================= -->
    <div class="bg-white border border-gray-200 shadow-sm rounded-xl p-5 overflow-x-auto">

      <h2 class="text-xl font-bold mb-4">Activities</h2>

      <!-- SEARCH -->
      <form method="GET" action="/activity" class="mb-4 flex gap-2">

        <input
          type="text"
          name="search"
          placeholder="Search activity name..."
          value="<%= search || '' %>"
          class="w-full border border-gray-300 p-2.5 rounded-lg bg-white
          focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition">

        <button
          type="submit"
          class="px-4 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium">
          Search
        </button>

        <a
          href="/activity"
          class="px-4 py-2.5 bg-gray-100 text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-200 transition font-medium">
          Clear
        </a>

      </form>

      <!-- HEADER ROW -->
      <div class="grid grid-cols-2 text-sm font-semibold text-gray-500 border-b border-gray-200 pb-2 mb-2">
        <span>Activity Name</span>
        <span class="text-right">Action</span>
      </div>

      <!-- LIST -->
      <% if (activities && activities.length) { %>

        <% for (const activity of activities) { %>

          <div class="grid grid-cols-2 py-3 border-b border-gray-200 hover:bg-blue-50 transition">

            <span class="font-medium text-gray-900">
              <%= activity.name %>
            </span>

            <span class="text-right">
              <a href="/activity/<%= activity.id %>"
                 class="text-blue-600 hover:underline font-medium">
                Edit
              </a>
            </span>

          </div>

        <% } %>

      <% } else { %>

        <p class="text-gray-500 mt-4">
          No activities found.
        </p>

      <% } %>

    </div>

    <!-- ================= CREATE / EDIT FORM ================= -->
    <div class="bg-white border border-gray-200 shadow-sm rounded-xl p-6">

      <% const isEdit = selectedActivity && selectedActivity.id; %>

      <h2 class="text-xl font-bold mb-4">
        <%= isEdit ? "Edit Activity" : "Create Activity" %>
      </h2>

      <form action="/activity/<%= isEdit ? selectedActivity.id : '' %>"
            method="post"
            class="space-y-4">

        <!-- ACTIVITY NAME -->
        <div>
          <label class="block text-sm font-medium text-gray-700">
            Activity Name
          </label>

          <input
            type="text"
            name="name"
            required
            value="<%= selectedActivity ? selectedActivity.name : '' %>"
            class="w-full mt-1 border border-gray-300 p-2.5 rounded-lg bg-white
            focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition">

             <% if (error) { %>
                   <p class="text-red-500 text-sm mt-1">
                     <%= error %>
                   </p>
                 <% } %>
                 
        </div>

        <!-- BUTTONS -->
        <div class="flex gap-3 pt-2">

          <button
            type="reset"
            class="px-4 py-2.5 bg-gray-100 text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-200 transition font-medium">
            Clear
          </button>

          <% if (!isEdit) { %>

            <button
              type="submit"
              name="action"
              value="create"
              class="px-4 py-2.5 bg-green-600 text-white rounded-lg hover:bg-green-700 transition font-medium">
              Create
            </button>

          <% } else { %>

            <button
              type="submit"
              name="action"
              value="update"
              class="px-4 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium">
              Update
            </button>

          <% } %>

          <button
            type="submit"
            name="action"
            value="delete"
            class="px-4 py-2.5 bg-red-600 text-white rounded-lg hover:bg-red-700 transition font-medium">
            Delete
          </button>

        </div>

      </form>

    </div>

  </section>

  <!-- FOOTER -->
  <%- include("partials/footer.ejs") %>

</main>

</body>
</html>