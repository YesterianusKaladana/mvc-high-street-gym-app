<!DOCTYPE html>
<html lang="en">

<head>
    <%- include("partials/head.ejs") %>
    <title>HSG - Trainer Manage Sessions</title>
</head>

<body class="bg-gray-50 text-gray-900">

<main class="min-h-screen flex flex-col">

    <div class="flex-1 max-w-7xl mx-auto w-full p-6">

        <!-- HEADER -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900">📅 My Sessions</h1>
            <p class="text-gray-600 mt-2">Create and manage your training sessions</p>
        </div>

        <!-- BACK -->
        <a href="/authenticate/dashboard"
           class="mb-6 inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium">
            ← Back to Dashboard
        </a>

        <!-- SEARCH -->
        <div class="mb-6 p-5 rounded-xl shadow-sm bg-white border border-gray-200">

            <form method="GET"
                  action="/session/trainer/view"
                  class="flex flex-nowrap items-end gap-4 overflow-x-auto">

                <!-- Activity -->
                <div class="flex flex-col min-w-[180px]">
                    <label class="text-sm font-medium text-gray-700 mb-1">Activity</label>
                    <input type="text" name="activity"
                        value="<%= activity || '' %>"
                        placeholder="Yoga, Pilates, etc."
                        class="w-full border border-gray-300 p-2.5 rounded-lg bg-white
                        focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"/>
                </div>
                
                <!-- Location -->
                <div class="flex flex-col min-w-[180px]">
                    <label class="text-sm font-medium text-gray-700 mb-1">Location</label>
                    <input type="text" name="location"
                        value="<%= location || '' %>"
                        placeholder="Ashgrove"
                        class="w-full border border-gray-300 p-2.5 rounded-lg bg-white
                        focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"/>
                </div>

                <!-- Date -->
                <div class="flex flex-col min-w-[160px]">
                    <label class="text-sm font-medium text-gray-700 mb-1">Date</label>
                    <input type="date" name="date"
                        value="<%= date || '' %>"
                        class="w-full border border-gray-300 p-2.5 rounded-lg bg-white
                        focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"/>
                </div>

                <!-- Start Time -->
                <div class="flex flex-col min-w-[160px]">
                    <label class="text-sm font-medium text-gray-700 mb-1">Start Time</label>
                    <input type="time" name="start_time"
                        value="<%= start_time || '' %>"
                        class="w-full border border-gray-300 p-2.5 rounded-lg bg-white
                        focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"/>
                </div>

                <!-- End Time -->
                <div class="flex flex-col min-w-[160px]">
                    <label class="text-sm font-medium text-gray-700 mb-1">End Time</label>
                    <input type="time" name="end_time"
                        value="<%= end_time || '' %>"
                        class="w-full border border-gray-300 p-2.5 rounded-lg bg-white
                        focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"/>
                </div>
                
                <!-- Capacity -->
                <div class="flex flex-col min-w-[160px]">
                    <label class="text-sm font-medium text-gray-700 mb-1">Capacity</label>
                    <input type="number" name="capacity"
                        value="<%= capacity || '' %>"
                        class="w-full border border-gray-300 p-2.5 rounded-lg bg-white
                        focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"/>
                </div>

                <!-- Buttons -->
                <div class="flex gap-2">
                    <button type="submit"
                        class="bg-blue-600 text-white px-4 py-2.5 rounded-lg hover:bg-blue-700 transition font-medium">
                        Search
                    </button>

                    <a href="/session/trainer/view"
                        class="bg-gray-100 text-gray-700 px-4 py-2.5 rounded-lg hover:bg-gray-200 transition font-medium border border-gray-300">
                        Clear
                    </a>
                </div>

            </form>

        </div>

        <section class="grid grid-cols-1 lg:grid-cols-3 gap-6">

            <!-- TABLE -->
            <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">

                <table class="w-full">

                    <thead class="bg-blue-600 text-white">
                        <tr>
                            <th class="px-6 py-3 text-left">Activity</th>
                            <th class="px-6 py-3 text-left">Date</th>
                            <th class="px-6 py-3 text-left">Start Time</th>
                            <th class="px-6 py-3 text-left">End Time</th>
                            <th class="px-6 py-3 text-left">Location</th>
                            <th class="px-6 py-3 text-left">Capacity</th>
                            <th class="px-6 py-3 text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                    <% if (sessions && sessions.length > 0) { %>

                        <% sessions.forEach(item => { %>

                            <tr class="border-b border-gray-200 hover:bg-blue-50 transition">

                                <td class="px-6 py-4 font-semibold text-gray-900">
                                    <%= item.activity.name %>
                                </td>

                                <td class="px-6 py-4 text-gray-700">
                                    <%= item.session.date
                                    ? new Date(item.session.date).toLocaleDateString("en-CA")
                                    : "" %>
                                </td>

                                <td class="px-6 py-4 text-gray-700">
                                    <%= item.session.start_time %>
                                </td>

                                <td class="px-6 py-4 text-gray-700">
                                    <%= item.session.end_time %>
                                </td>

                                <td class="px-6 py-4 text-gray-700">
                                    <%= item.location.name %>
                                </td>

                                <td class="px-6 py-4 text-gray-700">
                                    <%= item.session.capacity %>
                                </td>

                                <td class="px-6 py-4 text-center">

                                    <a href="/session/trainer/view?edit_id=<%= item.session.id %>"
                                       class="px-3 py-1.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium">
                                        Edit
                                    </a>

                                </td>

                            </tr>

                        <% }) %>

                    <% } else { %>

                        <tr>
                            <td colspan="6" class="text-center py-8 text-gray-500">
                                No sessions found. Create your first session!
                            </td>
                        </tr>

                    <% } %>

                    </tbody>

                </table>

            </div>

            <!-- FORM -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">

                <h2 class="text-xl font-bold mb-4 text-gray-900">
                    <%= selectedSession ? "Edit Session" : "Create New Session" %>
                </h2>

                <form method="POST" action="/session/trainer">

                    <input type="hidden"
                           name="action"
                           value="<%= selectedSession ? 'update' : 'create' %>">

                    <input type="hidden"
                           name="session_id"
                           value="<%= selectedSession?.session?.id || '' %>">

                    <!-- ACTIVITY -->
                    <div class="mb-4">
                        <label class="block mb-1 text-sm font-medium text-gray-700">Activity</label>

                        <select name="activity_id"
                                required
                                class="w-full border border-gray-300 p-2.5 rounded-lg bg-white
                                focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition">

                            <option value="">Select Activity</option>

                            <% activities.forEach(activity => { %>
                                <option
                                    value="<%= activity.id %>"
                                    <%= Number(selectedSession?.activity?.id) === Number(activity.id) ? 'selected' : '' %>>
                                    <%= activity.name %>
                                </option>
                            <% }) %>

                        </select>
                    </div>

                    <!-- DATE -->
                    <div class="mb-4">
                        <%
                        const today = new Date().toISOString().split("T")[0];
                        const selectedDate = selectedSession?.session?.date || '';
                        %>

                        <label class="block mb-1 text-sm font-medium text-gray-700">Date</label>

                        <input type="date"
                            name="date"
                            value="<%= selectedDate %>"
                            min="<%= today %>"
                            class="w-full border border-gray-300 p-2.5 rounded-lg bg-white
                            focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition"
                            required>
                    </div>

                    <!-- START TIME -->
                    <div class="mb-4">
                        <label class="block mb-1 text-sm font-medium text-gray-700">Start Time</label>

                        <input type="time"
                            name="start_time"
                            value="<%= selectedSession?.session?.start_time || '' %>"
                            class="w-full border border-gray-300 p-2.5 rounded-lg bg-white
                            focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition"
                            required>
                    </div>

                    <!-- END TIME -->
                    <div class="mb-4">
                        <label class="block mb-1 text-sm font-medium text-gray-700">End Time</label>

                        <input type="time"
                            name="end_time"
                            value="<%= selectedSession?.session?.end_time || '' %>"
                            class="w-full border border-gray-300 p-2.5 rounded-lg bg-white
                            focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition"
                            required>
                    </div>

                    <!-- LOCATION -->
                    <div class="mb-4">
                        <label class="block mb-1 text-sm font-medium text-gray-700">Location</label>

                        <select name="location_id"
                                required
                                class="w-full border border-gray-300 p-2.5 rounded-lg bg-white
                                focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition">

                            <option value="">Select Location</option>

                            <% locations.forEach(location => { %>
                                <option
                                    value="<%= location.id %>"
                                    <%= Number(selectedSession?.location?.id) === Number(location.id) ? 'selected' : '' %>>
                                    <%= location.name %>
                                </option>
                            <% }) %>

                        </select>
                    </div>

                    <!-- Capacity -->
                    <div class="flex flex-col min-w-[160px]">
                        <label class="text-sm font-medium text-gray-700 mb-1">Capacity</label>
                        <input type="number" name="capacity"
                            value="<%= selectedSession?.session.capacity || '' %>"
                            class="w-full border border-gray-300 p-2.5 rounded-lg bg-white
                            focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"/>
                    </div>

                    <!-- BUTTON -->
                    <button type="submit"
                        class="w-full bg-green-600 text-white py-2.5 rounded-lg hover:bg-green-700 transition font-medium">
                        <%= selectedSession ? "Update" : "Create" %>
                    </button>

                </form>

                <!-- DELETE -->
                <% if (selectedSession) { %>
                <form method="POST" action="/session/trainer" class="mt-3">
                    <input type="hidden" name="action" value="delete">
                    <input type="hidden" name="session_id" value="<%= selectedSession.session.id %>">

                    <button type="submit"
                        class="w-full bg-red-600 text-white py-2.5 rounded-lg hover:bg-red-700 transition font-medium">
                        Delete
                    </button>
                </form>
                <% } %>

            </div>

        </section>

    </div>

    <%- include("partials/footer.ejs") %>

</main>

</body>
</html>